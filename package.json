{
  "name": "@donbras/listboxkit",
  "version": "0.0.0-semantic-released",
  "description": "Small and flexible React hooks for building custom and accessible listbox components.",
  "repository": "git+https://github.com/DonBras/listboxkit.git",
  "types": "./src/Listbox.d.ts",
  "scripts": {
    "test": "jest",
    "test:ci": "jest --collect-coverage",
    "build": "rescript build",
    "clean": "rescript clean",
    "start": "rescript build -w",
    "docs:start": "cd docs && yarn start",
    "docs:build": "cd docs && yarn build",
    "bundle": "rollup -c rollup.config.js"
  },
  "main": "dist/listboxkit.cjs.js",
  "module": "dist/listboxkit.esm.js",
  "keywords": [
    "rescript",
    "react",
    "listbox",
    "select",
    "dropdown"
  ],
  "author": "Bernardo Gurgel <brnrdog@hey.com>",
  "contributors": [
    "Denis Meier <denis.meier1@gmail.com>"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.10.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=16.8.1"
  },
  "devDependencies": {
    "@glennsl/rescript-jest": "^0.11.0",
    "@rescript/react": "^0.11.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^12.1.5",
    "gentype": "^4.5.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "rescript": "^10.1.4",
    "rescript-dom-testing-library": "^1.15.0",
    "rescript-react-testing-library": "^1.3.0",
    "rollup": "^4.30.0",
    "rollup-plugin-analyzer": "^4.0.0",
    "semantic-release": "^24.2.1",
    "typescript": "^5.7.0"
  },
  "resolutions": {
    "jest": "^30.3.0",
    "@jest/core": "^30.3.0",
    "@jest/types": "^30.3.0",
    "serialize-javascript": "^7.0.5"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "<rootDir>/tests/*Test.bs.js"
    ],
    "collectCoverageFrom": [
      "<rootDir>/src/**/*.bs.js",
      "!<rootDir>/src/Controls/Controls.bs.js"
    ]
  },
  "release": {
    "branches": [
      "master"
    ],
    "tagFormat": "@donbras/listboxkit-v${version}",
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  },
  "volta": {
    "node": "20.20.2"
  }
}
